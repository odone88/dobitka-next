FOOTBALL_DATA_KEY=your_key_here

# Upstash Redis (optional — enables cross-request caching on Vercel)
# Get free tier at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Feature flags (all ON by default unless set to 'false')
NEXT_PUBLIC_FLAG_SCENARIOS=true
NEXT_PUBLIC_FLAG_TRANSFERS=true
NEXT_PUBLIC_FLAG_REDDIT=true
NEXT_PUBLIC_FLAG_RADARS=true
NEXT_PUBLIC_FLAG_WESZLO=true

# Experimental / off by default
NEXT_PUBLIC_FLAG_XG_TABLE=false
NEXT_PUBLIC_FLAG_NERD=false
